  m_Script: {fileID: 11500000, guid: b214ddfb8b3fffc4a8fe052105cc4230, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  flowerController: {fileID: 6067387632279355944}
  arCamera: {fileID: 0}
  autoFindCamera: 1
  butterflyDialoguePanel: {fileID: 5913282063165643025}
  butterflyDialogueText: {fileID: 1029819635877942155}
  useVoiceClipLength: 1
  openingDialogue:
  - Text: This is where Lumi rests now.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: "You brought a flower for Lumi. Let\u2019s place it beside the grave."
    VoiceClip: {fileID: 0}
    DisplaySeconds: 3
  emotionOrbDialogue:
  - Text: "Wait\u2026 Being here has brought up some strong feelings."
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: These lights represent sadness, anger, confusion, and loneliness.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: "Before we place the flower, let\u2019s care for each feeling."
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  allOrbsCompletedDialogue:
  - Text: You listened to every feeling.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: The feelings have not disappeared, but now they have been heard.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: You are ready to place the flower for Lumi.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  flowerPlacedDialogue:
  - Text: This flower is your goodbye to Lumi.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: "You can feel sad, angry, confused, or lonely\u2014and still remember the
      love you shared."
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: These feelings have formed a flower.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  - Text: Take it with you. The Memory Seed will need it.
    VoiceClip: {fileID: 0}
    DisplaySeconds: 2
  hintPanel: {fileID: 2671983492033618530}
  hintText: {fileID: 5124764190331045106}
  startFlowerHintText: "Place the flower beside Lumi\u2019s grave."
  orbHintText: Choose one emotion light.
  finalFlowerHintText: "Place the flower in front of Lumi\u2019s grave."
  flowerPlacedHintText: Collect the flower.

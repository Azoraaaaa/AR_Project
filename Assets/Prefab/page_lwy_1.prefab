  ModelsToHideDuringTask:
  - {fileID: 1720791522328680115}
  - {fileID: 1675926862991819562}
  Tasks:
  - OrbObject: {fileID: 7209279349360047901}
    TaskRoot: {fileID: 964679147082917039}
    IntroImage: {fileID: 21300000, guid: aad18634e8c2bcb4bac31c66f744342b, type: 3}
    IntroText: "It isn\u2019t fair that Lumi is gone!"
    IntroPanelSeconds: 3
    CompletionImage: {fileID: 21300000, guid: 592f9cfd2d877ff49ad8ed85a734ec79, type: 3}
    CompletionText: 'It is okay to feel angry.

      You found a safe way to let
      the anger out.'
    CompletionPanelSeconds: 3
    Completed: 0
  - OrbObject: {fileID: 2194215414852752959}
    TaskRoot: {fileID: 6021590048146064703}
    IntroImage: {fileID: 21300000, guid: 05b3177938e38f848a1fa635f35657ef, type: 3}
    IntroText: "Why can\u2019t Lumi come back?"
    IntroPanelSeconds: 3
    CompletionImage: {fileID: 21300000, guid: 592f9cfd2d877ff49ad8ed85a734ec79, type: 3}
    CompletionText: "When someone dies, their body stops working.\nThey cannot come
      back, and Lumi\u2019s death was not your fault.\nIt is always okay to ask questions."
    CompletionPanelSeconds: 3
    Completed: 0
  - OrbObject: {fileID: 1386022158217074135}
    TaskRoot: {fileID: 2220516124799650494}
    IntroImage: {fileID: 21300000, guid: 9b3fb24a790c1074197f3d979b115ceb, type: 3}
    IntroText: Everything feels empty without Lumi...
    IntroPanelSeconds: 3
    CompletionImage: {fileID: 21300000, guid: 592f9cfd2d877ff49ad8ed85a734ec79, type: 3}
    CompletionText: 'You do not have to miss Lumi alone.

      Your family and friends
      can stay with you when you feel lonely.'
    CompletionPanelSeconds: 3
    Completed: 0
  - OrbObject: {fileID: 6583566387674132881}
    TaskRoot: {fileID: 8414451730063619928}
    IntroImage: {fileID: 21300000, guid: 09ab87f05e8601246ae7d712f9e5c471, type: 3}
    IntroText: I miss Lumi, and I want to cry.
    IntroPanelSeconds: 0
    CompletionImage: {fileID: 21300000, guid: 592f9cfd2d877ff49ad8ed85a734ec79, type: 3}
    CompletionText: 'It is okay to cry when you miss someone.

      Sadness shows
      that Lumi was important to you.'
    CompletionPanelSeconds: 3
    Completed: 0
  ActivateOrbParentsWhenShown: 1

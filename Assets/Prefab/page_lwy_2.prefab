  butterflyDialoguePanel: {fileID: 7977361965978893539}
  butterflyDialogueText: {fileID: 4117673097074698284}
  useVoiceClipLength: 1
  dialogueTypingSeconds: 0.05
  openingDialogue:
  - Text: Welcome to the Memory Garden.
    VoiceClip: {fileID: 8300000, guid: 90c8bfac5e5095c42aab14c55a50b2c0, type: 3}
    DisplaySeconds: 2
  - Text: "We came here to find the memories that can help Lumi\u2019s Memory Seed
      grow."
    VoiceClip: {fileID: 8300000, guid: c450b5276349b9442b2e368706c41ea1, type: 3}
    DisplaySeconds: 2
  - Text: "Some memories of you and Lumi are floating in the pond\u2014use the net
      to collect them."
    VoiceClip: {fileID: 8300000, guid: ddf4d286dee2c4c47b41511c02a0910d, type: 3}
    DisplaySeconds: 2
  finalStarDialogue:
  - Text: You found the moments you shared with Lumi, and these memories will always
      be part of you.
    VoiceClip: {fileID: 8300000, guid: b19d97cb3059b6a47a95c013f48d9f7e, type: 3}
    DisplaySeconds: 2
  - Text: "Take the Memory Star with you\u2014the Memory Seed will need its light."
    VoiceClip: {fileID: 8300000, guid: c3f7a55726f2d6d4d9965c209f1ad2ed, type: 3}
    DisplaySeconds: 2
  showLightAreaOnDialogueLine: 3
  showNetOnDialogueLine: 4

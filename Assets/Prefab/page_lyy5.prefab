  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e6312e380caf6a44f82e2af34ab9568d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  narrationPanel: {fileID: 6220699656587586348}
  narrationText: {fileID: 9162723403349357649}
  narrationAudioSource: {fileID: 8403426171498707293}
  revealDurationRatio: 0.9
  fallbackCharactersPerSecond: 25
  timeBetweenLines: 0.3
  openingLines:
  - text: You brought the Memory Seed home.
    voiceClip: {fileID: 8300000, guid: 98b147024f1199640b49110a1bf68c33, type: 3}
  - text: Day by day, the little sprout continued to grow.
    voiceClip: {fileID: 8300000, guid: 98b147024f1199640b49110a1bf68c33, type: 3}
  middleLines:
  - text: You still missed Lumi sometimes.
    voiceClip: {fileID: 8300000, guid: d43b09275255bff4ea59c742d6313388, type: 3}
  - text: And it was okay to feel sad.
    voiceClip: {fileID: 8300000, guid: d43b09275255bff4ea59c742d6313388, type: 3}
  finalLines:
  - text: The flower reminded you that love and memories do not disappear.
    voiceClip: {fileID: 8300000, guid: d43b09275255bff4ea59c742d6313388, type: 3}
  - text: You could remember Lumi and keep growing.
    voiceClip: {fileID: 8300000, guid: d43b09275255bff4ea59c742d6313388, type: 3}
